# PayOS Configuration
PAYOS_CLIENT_ID=your_client_id
PAYOS_API_KEY=your_api_key
PAYOS_CHECKSUM_KEY=your_checksum_key

# Server config
PORT=24687
BASE_URL=http://localhost:24687

# Brevo SMTP (https://app.brevo.com)
BREVO_SMTP_KEY=your_smtp_key_here
BREVO_SMTP_LOGIN=your_login@smtp-brevo.com
BREVO_FROM_EMAIL=your-sender@domain.com
BREVO_FROM_NAME=Ý Niệm Điện Ảnh

# Firebase Admin — bắt buộc để xác thực quyền BTC và gửi thư mời lịch.
# Dán toàn bộ Service Account JSON trên một dòng.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id"}

# Google Calendar/Meet OAuth — dùng khi bật chế độ tạo Meet hoàn toàn tự động.
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.com/api/google/oauth/callback
GOOGLE_CALENDAR_REFRESH_TOKEN=refresh-token-after-admin-consent
GOOGLE_CALENDAR_ID=primary

# Bảo vệ tác vụ chốt lịch phỏng vấn tự động lúc 0h Việt Nam.
CRON_SECRET=replace_with_a_long_random_secret
SCHEDULE_PUBLIC_URL=https://yniemdienanh.vercel.app/schedule

# Gemini AI — nhiều API key và model được ngăn cách bằng dấu phẩy.
# Khi một model/key hết quota, server tự chuyển sang lựa chọn kế tiếp.
GEMINI_API_KEYS=your_gemini_api_key
GEMINI_MODELS=gemini-3-flash-preview,gemini-3.5-flash,gemini-2.5-flash,gemini-2.5-flash-lite,gemini-3.1-flash-lite,gemma-4-26b-a4b-it,gemma-4-31b-it

# Cloudflare Turnstile — lấy key tại https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# ================= SOCIAL MEDIA SYNC =================
# Khóa bảo vệ endpoint đồng bộ (để trống nếu muốn public)
SYNC_ADMIN_KEY=your_sync_secret_key

# Tần suất đồng bộ tự động (phút), mặc định 30
SYNC_INTERVAL_MINUTES=30

# --- YouTube Data API v3 ---
# Lấy API key tại https://console.cloud.google.com/apis/credentials
YT_API_KEY=your_youtube_api_key
# Channel ID (vd: UC... ) hoặc Handle (vd: @yniemdienanh)
YT_CHANNEL_ID=UC...
YT_HANDLE=@yniemdienanh

# --- Instagram Basic Display API ---
# Lấy access token từ Facebook Developer Console
IG_ACCESS_TOKEN=your_ig_access_token
IG_USER_ID=me

# --- TikTok API v2 ---
# Lấy từ TikTok Developer Portal (https://developers.tiktok.com)
TT_ACCESS_TOKEN=your_tiktok_access_token
TT_OPEN_ID=your_tiktok_open_id
