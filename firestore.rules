rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null
        && (
          request.auth.token.email_verified == true
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.emailVerified == true
          )
        );
    }

    function hasUserDoc() {
      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myRole() {
      return myUserDoc().data.role;
    }

    function isAdmin() {
      return isProjectAdminEmail() || (signedIn() && hasUserDoc() && myRole() == 'admin');
    }

    function isProjectAdminEmail() {
      return request.auth != null
        && request.auth.token.email == 'yniemdienanh@gmail.com'
        && request.auth.token.email_verified == true;
    }

    function validUserRoleOnCreate() {
      return (isProjectAdminEmail() && request.resource.data.role == 'admin')
        || (!isProjectAdminEmail() && request.resource.data.role == 'member');
    }

    function keepsOwnRole() {
      return !('role' in request.resource.data)
        || request.resource.data.role == resource.data.role
        || isProjectAdminEmail();
    }

    function isOrganizer() {
      return isProjectAdminEmail()
        || (signedIn() && hasUserDoc() && (myRole() == 'admin' || myRole() == 'organizer'));
    }

    // HR/PR staff coordinate polls, interviews and meeting attendance.
    function isScheduleManager() {
      return isOrganizer() || (signedIn() && hasUserDoc() && (
        myUserDoc().data.dept == 'Ban Nhân Sự' ||
        myUserDoc().data.dept == 'Ban Nhan Su' ||
        myUserDoc().data.dept == 'HR' ||
        myUserDoc().data.dept == 'Ban Truyền Thông' ||
        myUserDoc().data.dept == 'Ban Truyen Thong' ||
        myUserDoc().data.dept == 'PR' ||
        myUserDoc().data.dept == 'Ban PR/MKT' ||
        myUserDoc().data.dept == 'Marketing'
      ));
    }

    function isPeopleManager() {
      return isOrganizer() || (signedIn() && hasUserDoc() && (
        myUserDoc().data.dept == 'Ban Nhân Sự' ||
        myUserDoc().data.dept == 'Ban Nhan Su' ||
        myUserDoc().data.dept == 'HR' ||
        myUserDoc().data.dept == 'Ban Truyền Thông' ||
        myUserDoc().data.dept == 'Ban Truyen Thong' ||
        myUserDoc().data.dept == 'PR' ||
        myUserDoc().data.dept == 'Ban PR/MKT' ||
        myUserDoc().data.dept == 'Marketing'
      ));
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function canRespondToAvailabilityPoll(pollId) {
      return signedIn()
        && exists(/databases/$(database)/documents/availabilityPolls/$(pollId))
        && ("status" in get(/databases/$(database)/documents/availabilityPolls/$(pollId)).data && get(/databases/$(database)/documents/availabilityPolls/$(pollId)).data.status == 'open')
        && (
          ("isPublic" in get(/databases/$(database)/documents/availabilityPolls/$(pollId)).data && get(/databases/$(database)/documents/availabilityPolls/$(pollId)).data.isPublic == true)
          || ("participantIds" in get(/databases/$(database)/documents/availabilityPolls/$(pollId)).data && request.auth.uid in get(/databases/$(database)/documents/availabilityPolls/$(pollId)).data.participantIds)
          || isScheduleManager()
        );
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{docId} {
      allow read: if true;
      allow write: if isOrganizer();
    }

    match /submissions/{submissionId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.status == 'pending' && !('fee' in request.resource.data && request.resource.data.fee > 0);
      allow update, delete: if isOrganizer();

      match /votes/{userId} {
        allow read: if true;
        allow create: if signedIn()
          && request.auth.uid == userId
          && userId == request.resource.data.userId
          && submissionId == request.resource.data.submissionId
          && (!exists(/databases/$(database)/documents/config/settings) || (
              let settings = get(/databases/$(database)/documents/config/settings).data;
              (!("voteStart" in settings) || settings.voteStart == "" || request.time >= timestamp(settings.voteStart)) &&
              (!("voteEnd" in settings) || settings.voteEnd == "" || request.time <= timestamp(settings.voteEnd))
             ));
        allow update: if false;
        allow delete: if isOrganizer();
      }
    }

    match /feedback/{docId} {
      allow create: if true;
      allow read, update, delete: if isOrganizer();
    }

    match /users/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId && validUserRoleOnCreate();
      allow read: if request.auth != null && (request.auth.uid == userId || isPeopleManager());
      allow update: if signedIn() && ((request.auth.uid == userId && keepsOwnRole()) || isAdmin());
      allow delete: if isAdmin();
    }

    match /applications/{docId} {
      allow create: if signedIn();
      allow read, update, delete: if isPeopleManager();
    }

    match /tasks/{docId} {
      allow read: if signedIn();
      allow write: if isOrganizer();
    }

    match /plans/{docId} {
      allow read: if signedIn();
      allow write: if isOrganizer();
    }

    match /announcements/{docId} {
      allow read: if signedIn();
      allow write: if isOrganizer();
    }

    match /budget/{docId} {
      allow read, write: if isOrganizer();
    }

    match /docs/{docId} {
      allow read: if signedIn();
      allow write: if isOrganizer();
    }

    match /messages/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isOrganizer();
    }

    match /posts/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if signedIn() && (isOwner(resource.data.userId) || isOrganizer()) && (!('userRole' in request.resource.data) || request.resource.data.userRole == resource.data.userRole) && (!('pinned' in request.resource.data) || request.resource.data.pinned == resource.data.pinned) && (!('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId);
      allow delete: if isOrganizer();
    }

    match /comments/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isOrganizer();
    }

    match /transactions/{docId} {
      allow read: if isOrganizer() || (signedIn() && resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    match /registrations/{docId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isOrganizer());
      allow create: if signedIn() && (!('price' in request.resource.data) || request.resource.data.price == 0);
      allow update, delete: if isOrganizer();
    }

    // === NEW FEATURE COLLECTIONS ===

    match /support_questions/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isOrganizer();
    }

    match /support_faq/{docId} {
      allow read: if true;
      allow write: if isOrganizer();
    }

    match /onboarding_checklists/{docId} {
      allow read: if signedIn();
      allow write: if isOrganizer();
    }

    match /onboarding_progress/{userId} {
      allow read: if request.auth.uid == userId || isOrganizer();
      allow write: if request.auth.uid == userId || isOrganizer();
    }

    match /calendar_events/{docId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn() && (isOwner(resource.data.userId) || isOrganizer());
      allow delete: if isOrganizer();
    }

    // Lịch rảnh cá nhân và lịch chính thức do BTC/Admin điều phối.
    match /availabilityPolls/{pollId} {
      allow read: if isScheduleManager()
        || (signedIn()
          && ("status" in resource.data && resource.data.status == 'open')
          && (!exists(/databases/$(database)/documents/meetingSchedules/$(pollId + '_' + request.auth.uid))
            || !("completedAt" in get(/databases/$(database)/documents/meetingSchedules/$(pollId + '_' + request.auth.uid)).data))
          && (("isPublic" in resource.data && resource.data.isPublic == true)
            || ("participantIds" in resource.data && request.auth.uid in resource.data.participantIds)));
      allow create, update, delete: if isScheduleManager();
    }

    match /meetingSchedules/{docId} {
      allow read: if isScheduleManager()
        || (signedIn() && resource.data.ownerId == request.auth.uid && !("completedAt" in resource.data));
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && ('pollId' in request.resource.data)
        && !("completedAt" in request.resource.data)
        && docId == request.resource.data.pollId + '_' + request.auth.uid
        && canRespondToAvailabilityPoll(request.resource.data.pollId);
      allow update: if signedIn()
        && (resource.data.ownerId == request.auth.uid || isScheduleManager())
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.pollId == resource.data.pollId
        && (isScheduleManager()
          || (!("completedAt" in resource.data)
            && !("completedAt" in request.resource.data)
            && canRespondToAvailabilityPoll(resource.data.pollId)));
      allow delete: if isScheduleManager()
        || (signedIn() && resource.data.ownerId == request.auth.uid
          && ('pollId' in resource.data)
          && !("completedAt" in resource.data)
          && canRespondToAvailabilityPoll(resource.data.pollId));
    }

    match /scheduledEvents/{eventId} {
      allow read: if isScheduleManager()
        || (signedIn() && (
          ("isPublic" in resource.data && resource.data.isPublic == true)
          || ("participantIds" in resource.data && request.auth.uid in resource.data.participantIds)
          || exists(/databases/$(database)/documents/scheduledBookings/$(eventId + '_' + request.auth.uid))
          || ("availabilityPollId" in resource.data && canRespondToAvailabilityPoll(resource.data.availabilityPollId))
        ));
      allow create, update, delete: if isScheduleManager();
    }

    match /scheduledBookings/{bookingId} {
      allow read: if signedIn() && (resource.data.candidateId == request.auth.uid || isScheduleManager());
      allow create: if signedIn()
        && bookingId == request.resource.data.eventId + '_' + request.auth.uid
        && request.resource.data.candidateId == request.auth.uid
        && request.resource.data.status == 'requested'
        && exists(/databases/$(database)/documents/scheduledEvents/$(request.resource.data.eventId))
        && get(/databases/$(database)/documents/scheduledEvents/$(request.resource.data.eventId)).data.status != 'cancelled'
        && (
          ("isPublic" in get(/databases/$(database)/documents/scheduledEvents/$(request.resource.data.eventId)).data && get(/databases/$(database)/documents/scheduledEvents/$(request.resource.data.eventId)).data.isPublic == true)
          || ("participantIds" in get(/databases/$(database)/documents/scheduledEvents/$(request.resource.data.eventId)).data && request.auth.uid in get(/databases/$(database)/documents/scheduledEvents/$(request.resource.data.eventId)).data.participantIds)
          || ("availabilityPollId" in get(/databases/$(database)/documents/scheduledEvents/$(request.resource.data.eventId)).data && canRespondToAvailabilityPoll(get(/databases/$(database)/documents/scheduledEvents/$(request.resource.data.eventId)).data.availabilityPollId))
        );
      allow create: if isScheduleManager()
        && bookingId == request.resource.data.eventId + '_' + request.resource.data.candidateId
        && request.resource.data.status in ['requested', 'confirmed'];
      allow update: if isScheduleManager();
      allow delete: if signedIn() && (resource.data.candidateId == request.auth.uid || isScheduleManager());
    }

    match /staffPoints/{pointId} {
      allow read: if signedIn();
      allow create, update, delete: if isOrganizer();
    }

    match /notifications/{docId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || resource.data.targetAll == true || isOrganizer());
      allow create: if signedIn();
      allow update: if signedIn() && (resource.data.userId == request.auth.uid || isOrganizer());
      allow delete: if isOrganizer();
    }

    match /deadline_extensions/{docId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isOrganizer();
    }

    match /teams/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if signedIn() && (isOwner(resource.data.leaderId) || isOrganizer());
      allow delete: if isOrganizer();
    }

    match /team_members/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if isOrganizer();
      allow delete: if signedIn() || isOrganizer();
    }

    match /production_handbooks/{docId} {
      allow read: if signedIn();
      allow write: if signedIn() && (isOwner(resource.data.userId) || isOrganizer());
    }

    match /crew_finder/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if signedIn() && (isOwner(resource.data.userId) || isOrganizer());
      allow delete: if isOrganizer();
    }

    match /crew_applications/{docId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isOrganizer();
    }

    match /talent_profiles/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if signedIn() && (isOwner(resource.data.userId) || isOrganizer());
      allow delete: if isOrganizer();
    }

    match /film_locations/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if signedIn() && (isOwner(resource.data.userId) || isOrganizer());
      allow delete: if isOrganizer();
    }

    match /equipment/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if signedIn() && (isOwner(resource.data.userId) || isOrganizer());
      allow delete: if isOrganizer();
    }

    match /equipment_requests/{docId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isOrganizer();
    }

    match /film_ideas/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if signedIn() && (isOwner(resource.data.userId) || isOrganizer());
      allow delete: if isOrganizer();
    }

    match /idea_comments/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if signedIn() && isOwner(resource.data.userId);
      allow delete: if isOrganizer();
    }

    match /peer_reviews/{docId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn() && isOwner(resource.data.userId);
      allow delete: if isOrganizer();
    }

    match /production_diaries/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if signedIn() && (isOwner(resource.data.userId) || isOrganizer());
      allow delete: if isOrganizer();
    }

    match /risk_reports/{docId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isOrganizer();
    }

    match /trailers/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if isOrganizer();
      allow delete: if isOrganizer();
    }

    match /brand_kits/{docId} {
      allow read: if true;
      allow write: if isOrganizer();
    }

    match /media_tasks/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if signedIn() && (isOwner(resource.data.userId) || isOrganizer());
    }

    match /surveys/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if isOrganizer();
      allow delete: if isOrganizer();
    }

    match /survey_responses/{docId} {
      allow read: if isOrganizer();
      allow create: if signedIn();
      allow update: if false;
    }

    match /alumni/{docId} {
      allow read: if true;
      allow write: if isOrganizer();
    }

    match /community_map/{docId} {
      allow read: if true;
      allow write: if isOrganizer();
    }

    match /seasons/{docId} {
      allow read: if true;
      allow write: if isOrganizer();
    }

    match /season_themes/{docId} {
      allow read: if true;
      allow write: if isOrganizer();
    }

    match /workshops/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if isOrganizer();
      allow delete: if isOrganizer();
    }

    match /workshop_registrations/{docId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isOrganizer());
      allow create: if signedIn();
      allow update: if isOrganizer();
    }

    match /mentors/{docId} {
      allow read: if true;
      allow write: if isOrganizer();
    }

    match /mentor_questions/{docId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if isOrganizer();
    }

    match /competition_categories/{docId} {
      allow read: if true;
      allow write: if isOrganizer();
    }

    match /production_progress/{docId} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /mini_challenges/{docId} {
      allow read: if true;
      allow write: if isOrganizer();
    }

    match /mini_challenge_submissions/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if isOrganizer();
    }

    match /judging/{docId} {
      allow read: if isOrganizer();
      allow write: if isOrganizer();
    }

    match /judging_scores/{docId} {
      allow read: if isOrganizer();
      allow write: if isOrganizer();
    }

    match /leaderboard/{docId} {
      allow read: if true;
      allow write: if isOrganizer();
    }

    match /gala/{docId} {
      allow read: if true;
      allow write: if isOrganizer();
    }

    match /certificates/{docId} {
      allow read: if true;
      allow write: if isOrganizer();
    }

    match /partners/{docId} {
      // Hồ sơ hợp tác có thể chứa thông tin đầu mối, quyền lợi và cam kết.
      allow read: if isOrganizer();
      allow write: if isOrganizer();
    }

    match /ambassadors/{docId} {
      allow read: if true;
      allow write: if isOrganizer();
    }

    match /ambassador_referrals/{docId} {
      allow read: if isOrganizer();
      allow create: if signedIn();
    }

    match /school_partners/{docId} {
      // Số điện thoại/email của đầu mối trường/CLB chỉ dành cho BTC.
      allow read: if isOrganizer();
      allow write: if isOrganizer();
    }

    match /kpi/{docId} {
      allow read: if signedIn();
      allow write: if isOrganizer();
    }

    match /film_archive/{docId} {
      allow read: if true;
      allow write: if isOrganizer();
    }

    match /learning_library/{docId} {
      allow read: if true;
      allow write: if isOrganizer();
    }

    match /music_library/{docId} {
      allow read: if true;
      allow write: if isOrganizer();
    }

    match /learning_progress/{docId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isOrganizer());
      allow write: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /student_portfolios/{docId} {
      allow read: if true;
      allow write: if signedIn() && (isOwner(resource.data.userId) || isOrganizer());
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
