rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null
        && (
          request.auth.token.email_verified == true
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.emailVerified == true
          )
        );
    }

    function hasUserDoc() {
      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myRole() {
      return myUserDoc().data.role;
    }

    function isAdmin() {
      return signedIn() && hasUserDoc() && myRole() == 'admin';
    }

    function isProjectAdminEmail() {
      return request.auth != null
        && request.auth.token.email == 'yniemdienanh@gmail.com'
        && request.auth.token.email_verified == true;
    }

    function validUserRoleOnCreate() {
      return (isProjectAdminEmail() && request.resource.data.role == 'admin')
        || (!isProjectAdminEmail() && request.resource.data.role == 'member');
    }

    function keepsOwnRole() {
      return !('role' in request.resource.data)
        || request.resource.data.role == resource.data.role
        || isProjectAdminEmail();
    }

    function isOrganizer() {
      return signedIn() && hasUserDoc() && (myRole() == 'admin' || myRole() == 'organizer');
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{docId} {
      allow read: if true;
      allow write: if isOrganizer();
    }

    match /submissions/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isOrganizer();
    }

    match /votes/{docId} {
      allow read: if isOrganizer();
      allow create: if true;
      allow update, delete: if false;
    }

    match /feedback/{docId} {
      allow create: if true;
      allow read, update, delete: if isOrganizer();
    }

    match /users/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId && validUserRoleOnCreate();
      allow read: if request.auth != null && (request.auth.uid == userId || isOrganizer());
      allow update: if signedIn() && ((request.auth.uid == userId && keepsOwnRole()) || isAdmin());
      allow delete: if isAdmin();
    }

    match /applications/{docId} {
      allow create: if true;
      allow read, update, delete: if isOrganizer();
    }

    match /tasks/{docId} {
      allow read: if signedIn();
      allow write: if isOrganizer();
    }

    match /plans/{docId} {
      allow read: if signedIn();
      allow write: if isOrganizer();
    }

    match /announcements/{docId} {
      allow read: if signedIn();
      allow write: if isOrganizer();
    }

    match /budget/{docId} {
      allow read, write: if isOrganizer();
    }

    match /docs/{docId} {
      allow read: if signedIn();
      allow write: if isOrganizer();
    }

    match /messages/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isOrganizer();
    }

    match /posts/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if signedIn() && (isOwner(resource.data.userId) || isOrganizer());
      allow delete: if isOrganizer();
    }

    match /comments/{docId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if isOrganizer();
    }

    match /transactions/{docId} {
      allow read: if isOrganizer();
      allow create: if signedIn();
      allow update: if isOrganizer();
      allow delete: if isOrganizer();
    }

    match /registrations/{docId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isOrganizer();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
