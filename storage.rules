rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // The web application currently stores only one public avatar per user.
    // Keep every other path deny-by-default until a reviewed upload use-case
    // has an explicit owner/type/size policy.
    match /avatars/{userId}/avatar {
      allow read: if true;

      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
